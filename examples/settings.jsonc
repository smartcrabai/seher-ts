{
	// JSON Schema for editor validation / completion.
	"$schema": "https://raw.githubusercontent.com/seher-ts/seher-ts/main/schemas/settings.schema.json",

	// Priority rules: higher values win when multiple non-limited agents match.
	"priority": [
		{
			"command": "opencode",
			"provider": "copilot",
			"model": "high",
			"priority": 100,
		},
		{
			"command": "codex",
			"priority": 50,
		},
		{
			// provider: null -> skip provider-based rate-limit checks for this rule.
			"command": "claude",
			"provider": null,
			"model": "medium",
			"priority": 25,
		},
		{
			"command": "claude",
			"model": "low",
			"priority": 10,
		},
	],

	"agents": [
		{
			// Default Claude agent, driven through the Anthropic SDK.
			"command": "claude",
			"args": ["--model", "{model}"],
			"models": {
				"low": "haiku",
				"medium": "sonnet",
				"high": "opus",
				"sonnet": "sonnet",
			},
			"arg_maps": {
				// Expand `--danger` on the CLI tail into a safer explicit flag set.
				"--danger": ["--permission-mode", "bypassPermissions"],
			},
			"env": {
				"CLAUDE_CODE_MAX_TURNS": "100",
			},
			"sdk": "claude",
		},
		{
			"command": "opencode",
			"args": ["--model", "{model}", "--yolo"],
			"models": {
				"high": "github-copilot/gpt-5.4",
				"medium": "github-copilot/gpt-5.4",
				"low": "github-copilot/claude-haiku-4.5",
			},
			"provider": "copilot",
		},
		{
			// Codex agent, driven through the Codex SDK.
			"command": "codex",
			"pre_command": ["git", "pull", "--rebase"],
			"sdk": "codex",
		},
		{
			// Alternate Claude endpoint (DashScope). provider=null -> treated as
			// a fallback that is never considered rate-limited.
			"command": "claude",
			"args": ["--model", "{model}"],
			"models": {
				"low": "MiniMax-M2.5",
				"medium": "MiniMax-M2.5",
			},
			"env": {
				"ANTHROPIC_AUTH_TOKEN": "your-api-key-here",
				"ANTHROPIC_BASE_URL": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic",
			},
			"provider": null,
		},
	],
}
