{
  "name": "seher-ts-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/sdk build && bun run --cwd packages/cli build",
    "lint": "biome check ./packages",
    "lint:fix": "biome check --write --unsafe ./packages",
    "test": "bun test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260422.1",
    "typescript": "^5.9.3"
  }
}
